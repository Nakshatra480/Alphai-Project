# AlphaI BTC Forecaster — environment variables
# Copy this to .env and fill in your values

# MongoDB Atlas connection string (for Part C persistence)
# Get a free M0 cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/alphai_btc?retryWrites=true&w=majority

# Internal Flask microservice URL (same machine in dev)
FLASK_URL=http://localhost:5001

# React frontend URL (for CORS — update for production)
CLIENT_URL=http://localhost:5173

# Express port
PORT=5000

# Production: set FLASK_URL to your Render Flask service URL
# e.g. FLASK_URL=https://alphai-flask.onrender.com
